---
layout: default
---
<div class="home-draft home-draft--signal home-draft--live">
  <article>
    <section class="home-draft__hero">
      <div class="home-draft__intro">
        <p class="home-draft__subtitle">{{ page.subtitle }}</p>
        <h1 class="home-draft__title">
          {% if site.title == 'blank' %}
            <span>{{ site.first_name }}</span>
            {% if site.middle_name %}{{ site.middle_name }}{% endif %}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>
        <div class="home-draft__bio">{{ content }}</div>

        {% if page.social %}
          <div class="home-draft__social">
            {% include home_social_links.liquid %}
            <div class="contact-note">{{ site.contact_note }}</div>
          </div>
        {% endif %}
      </div>

      {% if page.profile and page.profile.image %}
        <aside class="home-draft__portrait" aria-label="Profile photo">
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% capture sizes %}(min-width: {{ site.max_width }}) 320px, (min-width: 576px) 38vw, 92vw{% endcapture %}
          {% include figure.liquid
            loading="eager"
            path=profile_image_path
            class="img-fluid"
            sizes=sizes
            alt=page.profile.image
            cache_bust=true
          %}
          {% if page.profile.more_info %}
            <div class="home-draft__more-info">{{ page.profile.more_info }}</div>
          {% endif %}
        </aside>
      {% endif %}
    </section>

    {% if page.announcements and page.announcements.enabled %}
      <section class="home-draft__section">
        <h2><a href="{{ '/news/' | relative_url }}">news</a></h2>
        {% include news.liquid limit=true %}
      </section>
    {% endif %}

    {% if page.latest_posts and page.latest_posts.enabled %}
      <section class="home-draft__section">
        <h2><a href="{{ '/blog/' | relative_url }}">latest posts</a></h2>
        {% include latest_posts.liquid %}
      </section>
    {% endif %}

    {% if page.selected_papers %}
      <section class="home-draft__section home-draft__section--publications">
        <h2><a href="{{ '/publications/' | relative_url }}">selected publications</a></h2>
        {% include selected_papers.liquid %}
      </section>
    {% endif %}
  </article>

  {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
    {% include newsletter.liquid center=true %}
  {% endif %}
</div>
